{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "rg-azure-networking-labs",
      "metadata": { "description": "Name of the resource group to deploy into. Use the default unless you have a specific reason to change it." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region. Defaults to resource group location." }
    },
    "sessionKey": {
      "type": "string",
      "defaultValue": "[newGuid()]",
      "metadata": { "description": "Session key for unique unlock code generation." }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-09-01",
      "name": "vnet-spoke1",
      "location": "[parameters('location')]",
      "tags": {
        "lab": "azure-networking-labs",
        "module": "03-peering",
        "resourceGroup": "[parameters('resourceGroupName')]",
        "sessionKey": "[take(toUpper(parameters('sessionKey')), 8)]"
      },
      "properties": {
        "addressSpace": { "addressPrefixes": [ "10.1.0.0/16" ] },
        "subnets": [
          { "name": "snet-workloads", "properties": { "addressPrefix": "10.1.1.0/24" } }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
      "apiVersion": "2023-09-01",
      "name": "vnet-hub/peer-hub-to-spoke1",
      "dependsOn": [ "[resourceId('Microsoft.Network/virtualNetworks', 'vnet-spoke1')]" ],
      "properties": {
        "remoteVirtualNetwork": { "id": "[resourceId('Microsoft.Network/virtualNetworks', 'vnet-spoke1')]" },
        "allowVirtualNetworkAccess": true,
        "allowForwardedTraffic": true,
        "allowGatewayTransit": false,
        "useRemoteGateways": false
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
      "apiVersion": "2023-09-01",
      "name": "vnet-spoke1/peer-spoke1-to-hub",
      "dependsOn": [ "[resourceId('Microsoft.Network/virtualNetworks', 'vnet-spoke1')]" ],
      "properties": {
        "remoteVirtualNetwork": { "id": "[resourceId('Microsoft.Network/virtualNetworks', 'vnet-hub')]" },
        "allowVirtualNetworkAccess": true,
        "allowForwardedTraffic": true,
        "allowGatewayTransit": false,
        "useRemoteGateways": false
      }
    }
  ],
  "outputs": {
    "spokeVnetId":      { "type": "string", "value": "[resourceId('Microsoft.Network/virtualNetworks', 'vnet-spoke1')]" },
    "spokeVnetName":    { "type": "string", "value": "vnet-spoke1" },
    "resourceGroupUsed": { "type": "string", "value": "[resourceGroup().name]" }
  }
}
