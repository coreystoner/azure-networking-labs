{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region." }
    },
    "hubApplianceIp": {
      "type": "string",
      "defaultValue": "10.0.4.4",
      "metadata": { "description": "IP of the hub NVA or Azure Firewall (Module 05)." }
    },
    "sessionKey": {
      "type": "string",
      "defaultValue": "[newGuid()]",
      "metadata": { "description": "Session key for unique unlock code generation." }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2023-09-01",
      "name": "rt-web",
      "location": "[parameters('location')]",
      "tags": {
        "lab": "azure-networking-labs",
        "module": "04-routing-udrs",
        "sessionKey": "[take(toUpper(parameters('sessionKey')), 8)]"
      },
      "properties": {
        "disableBgpRoutePropagation": false,
        "routes": [
          {
            "name": "route-internet-via-appliance",
            "properties": {
              "addressPrefix": "0.0.0.0/0",
              "nextHopType": "VirtualAppliance",
              "nextHopIpAddress": "[parameters('hubApplianceIp')]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2023-09-01",
      "name": "rt-app",
      "location": "[parameters('location')]",
      "tags": { "lab": "azure-networking-labs", "module": "04-routing-udrs" },
      "properties": {
        "disableBgpRoutePropagation": false,
        "routes": [
          {
            "name": "route-internet-via-appliance",
            "properties": {
              "addressPrefix": "0.0.0.0/0",
              "nextHopType": "VirtualAppliance",
              "nextHopIpAddress": "[parameters('hubApplianceIp')]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2023-09-01",
      "name": "rt-data",
      "location": "[parameters('location')]",
      "tags": { "lab": "azure-networking-labs", "module": "04-routing-udrs" },
      "properties": {
        "disableBgpRoutePropagation": true,
        "routes": [
          {
            "name": "blackhole-internet",
            "properties": { "addressPrefix": "0.0.0.0/0", "nextHopType": "None" }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2023-09-01",
      "name": "vnet-hub/snet-web",
      "dependsOn": [ "[resourceId('Microsoft.Network/routeTables', 'rt-web')]" ],
      "properties": {
        "addressPrefix": "10.0.1.0/24",
        "routeTable": { "id": "[resourceId('Microsoft.Network/routeTables', 'rt-web')]" }
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2023-09-01",
      "name": "vnet-hub/snet-app",
      "dependsOn": [
        "[resourceId('Microsoft.Network/routeTables', 'rt-app')]",
        "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'vnet-hub', 'snet-web')]"
      ],
      "properties": {
        "addressPrefix": "10.0.2.0/24",
        "routeTable": { "id": "[resourceId('Microsoft.Network/routeTables', 'rt-app')]" }
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2023-09-01",
      "name": "vnet-hub/snet-data",
      "dependsOn": [
        "[resourceId('Microsoft.Network/routeTables', 'rt-data')]",
        "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'vnet-hub', 'snet-app')]"
      ],
      "properties": {
        "addressPrefix": "10.0.3.0/24",
        "routeTable": { "id": "[resourceId('Microsoft.Network/routeTables', 'rt-data')]" }
      }
    }
  ],
  "outputs": {
    "rtWebId":  { "type": "string", "value": "[resourceId('Microsoft.Network/routeTables', 'rt-web')]" },
    "rtAppId":  { "type": "string", "value": "[resourceId('Microsoft.Network/routeTables', 'rt-app')]" },
    "rtDataId": { "type": "string", "value": "[resourceId('Microsoft.Network/routeTables', 'rt-data')]" }
  }
}
