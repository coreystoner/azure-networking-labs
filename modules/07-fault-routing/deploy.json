{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "rg-azure-networking-labs",
      "metadata": { "description": "Name of the resource group to deploy into. Use the default unless you have a specific reason to change it." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region." }
    },
    "sessionKey": {
      "type": "string",
      "defaultValue": "[newGuid()]",
      "metadata": { "description": "Session key for unique unlock code generation." }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2023-09-01",
      "name": "rt-web-fault",
      "location": "[parameters('location')]",
      "tags": {
        "lab": "azure-networking-labs",
        "module": "07-fault-routing",
        "fault": "blackhole-route",
        "resourceGroup": "[parameters('resourceGroupName')]",
        "sessionKey": "[take(toUpper(parameters('sessionKey')), 8)]"
      },
      "properties": {
        "routes": [
          {
            "name": "route-to-internet",
            "properties": { "addressPrefix": "0.0.0.0/0", "nextHopType": "None" }
          },
          {
            "name": "route-vnet-local",
            "properties": { "addressPrefix": "10.0.0.0/16", "nextHopType": "VnetLocal" }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2023-09-01",
      "name": "vnet-hub/snet-web-fault2",
      "dependsOn": [ "[resourceId('Microsoft.Network/routeTables', 'rt-web-fault')]" ],
      "properties": {
        "addressPrefix": "10.0.11.0/24",
        "routeTable": { "id": "[resourceId('Microsoft.Network/routeTables', 'rt-web-fault')]" }
      }
    }
  ],
  "outputs": {
    "rtFaultId": { "type": "string", "value": "[resourceId('Microsoft.Network/routeTables', 'rt-web-fault')]" },
    "resourceGroupUsed": { "type": "string", "value": "[resourceGroup().name]" }
  }
}
